# Database (Railway provides this automatically when you add a Postgres plugin)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Auth - generate a long random string, e.g.: openssl rand -base64 32
JWT_SECRET=your-super-secret-jwt-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-...

# SAM.gov API Key (get from https://sam.gov - Account Details > Public API Key)
SAM_API_KEY=your-sam-api-key-here

# Stripe (billing)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Environment
NODE_ENV=production

# Optional: lock CORS to your Railway domain
# FRONTEND_URL=https://your-app.up.railway.app
